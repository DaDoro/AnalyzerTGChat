# ============================================================
# AnalyzerTGChat — конфигурация
# Скопируйте этот файл в .env и заполните значения.
# ============================================================

# ===== Telegram API (для экспорта чатов) =====
# Получить на https://my.telegram.org -> API development tools
API_ID=
API_HASH=

# ===== Статистика слов (chat_word_stats) =====
# Минимальная длина слова, чтобы оно учитывалось
MIN_LEN=3
# Размер ТОП-списка слов / участников
TOP_N=30

# ===== Разделение чата на части (split_chat) =====
# Целевой размер части в символах. Если часть выходит больше этого порога,
# её дополнительно разрежет пополам по дате. 0 = не использовать.
# Рекомендация: 250_000 символов ≈ 60-80K токенов на русском.
MAX_CHARS_PER_PART=250000
# Объединять подряд идущие сообщения одного автора (в пределах N минут).
# Сильно уменьшает шум в чате-«пулемёте». 0 = не объединять.
MERGE_BURSTS_MINUTES=0
# Минимальная длина текста после очистки, иначе сообщение выкидывается.
MIN_TEXT_LEN=1
# Сворачивать длинные «ахаха»/«ыы»/«пхпхпх» к короткому виду.
NORMALIZE_LAUGHTER=False

# ===== Анализ через Claude API (analyze_parts) =====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Модель для анализа отдельных частей (быстрая/дешёвая)
MODEL_PARTS=claude-sonnet-4-6
# Модель для финального синтеза (более глубокая)
MODEL_FINAL=claude-opus-4-7
# Сколько частей анализировать одновременно
PARALLEL_WORKERS=4

# ===== Опциональные параметры (можно не задавать) =====
# Стратегия разделения: quarter (по кварталам) или month (по месяцам)
# SPLIT_BY=quarter
# Удалять сообщения, состоящие только из ссылки
# DROP_URL_ONLY=True
# Потолок длины ответа на одну часть (Sonnet 4.6 = 64000)
# MAX_TOKENS_PART=64000
# Потолок длины финального отчёта (Opus 4.7 = 32000)
# MAX_TOKENS_FINAL=32000
# Корневая папка для всех данных (экспорты, части, отчёты)
# OUTPUT_DIR_BASE=./data
# Папка с шаблонами промптов
# PROMPTS_DIR=./prompts
